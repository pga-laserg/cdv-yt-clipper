# Core API keys
OPENAI_API_KEY=
HF_TOKEN=

# YouTube ingest quality controls
# Preferred minimum source height (0 disables the quality gate).
YTDLP_MIN_PREFERRED_HEIGHT=720
# If preferred quality fails, allow best available fallback instead of hard-fail.
YTDLP_ALLOW_LOW_QUALITY_FALLBACK=true
# Optional browser profile for cookies (helps avoid YouTube 403 on high formats).
# Example: chrome, firefox, safari
YTDLP_COOKIES_FROM_BROWSER=
# Keep android fallback strategy as last resort.
YTDLP_ENABLE_ANDROID_FALLBACK=true

# Optional model overrides
ANALYZE_OPENAI_MODEL=gpt-5-mini
HIGHLIGHTS_OPENAI_MODEL=gpt-5-mini

# Boundary adjudication / policy
BOUNDARY_ENABLE_SINGLE_LLM_ADJUDICATOR=true
BOUNDARY_POLICY_INCLUDE_PRAYER=true
BOUNDARY_POLICY_INCLUDE_BENEDICTION=true
BOUNDARY_POLICY_INCLUDE_ALTAR_CALL=true
BOUNDARY_POLICY_INCLUDE_RESPONSE_MUSIC=true

# OCR multimodal cues (lower-thirds/slides/lyrics + scene cuts)
ANALYSIS_ENABLE_OCR_SIGNALS=true
OCR_BACKEND=auto
# Prefer HQ source for OCR passes even if pipeline analyze runs with source.light.mp4
OCR_PREFER_HQ_SOURCE=true
# OCR pipeline selector: v1 (legacy), v2 (detect/track/fuse), v3 (3-lane: slides/lower-third/lyrics)
OCR_PIPELINE=v1
OCR_SAMPLE_SEC=2.5
# 0 = full duration
OCR_MAX_DURATION_SEC=0
OCR_SCENE_CUT_THRESHOLD=0.32
OCR_MERGE_GAP_SEC=4.5
OCR_NEAR_SCENE_CUT_SEC=3.0
# Targeted OCR gating (fast text-likelihood pre-pass)
OCR_TARGETED=true
OCR_TARGET_THRESHOLD_LOWER_THIRD=0.16
OCR_TARGET_THRESHOLD_SLIDE=0.20
OCR_TARGET_THRESHOLD_FULL=0.24
OCR_TARGET_PERSIST_RELAX=0.82
OCR_TARGET_FORCE_EVERY_SAMPLES=6
OCR_TARGET_MAX_ROIS_PER_SAMPLE=2
OCR_TARGET_SCENE_CUT_BOOST=0.05
OCR_TARGET_RESIZE_MAX_WIDTH=640
OCR_TARGET_EMIT_PRESENCE=true
OCR_TARGET_PRESENCE_THRESHOLD=0.14
OCR_TARGET_PRESENCE_MIN_DURATION_SEC=3.0
OCR_TARGET_PRESENCE_MERGE_GAP_SEC=8.0
OCR_MIN_TEXT_CONFIDENCE=0.10
OCR_PREPROC_FALLBACK=true
# Restrict OCR to selected regions if needed (comma-separated: lower_third,slide,full)
OCR_REGIONS=lower_third,slide,full
# Tunable lower-third crop (normalized 0..1 in source frame)
OCR_LOWER_THIRD_Y1=0.68
OCR_LOWER_THIRD_Y2=0.92
OCR_LOWER_THIRD_X1=0.06
OCR_LOWER_THIRD_X2=0.94
# 0 = auto (~5% progress ticks). Set a fixed sample interval for more/less frequent logs.
OCR_PROGRESS_EVERY_SAMPLES=0
# Emit machine-readable JSON progress lines to stderr with prefix: [ocr-events-progress]
OCR_PROGRESS_JSON=true
# Languages for OCR engines:
# - EasyOCR: comma list (e.g. es,en)
# - Tesseract: use TESSERACT_LANG (e.g. spa+eng)
OCR_LANG=es,en
TESSERACT_LANG=spa+eng
# Optional binary overrides
OCR_PYTHON_BIN=
TESSERACT_BIN=

# OCR v2 scaffold (detect -> track -> OCR -> temporal fusion)
OCR_V2_SAMPLE_SEC=1.0
# 0 = full duration
OCR_V2_MAX_DURATION_SEC=0
OCR_V2_BACKEND=tesseract
OCR_V2_REGIONS=lower_third,slide
OCR_V2_SLIDE_Y1=0.08
OCR_V2_SLIDE_Y2=0.48
OCR_V2_SLIDE_X1=0.08
OCR_V2_SLIDE_X2=0.92
# EAST detector controls
OCR_V2_EAST_ENABLED=true
# Optional explicit EAST model path (if empty, resolved from model dir or downloaded)
OCR_V2_EAST_MODEL=
OCR_V2_EAST_MODEL_DIR=
OCR_V2_EAST_AUTO_DOWNLOAD=true
# Optional custom URL(s), comma-separated
OCR_V2_EAST_URL=
# Optional checksum validation
OCR_V2_EAST_SHA256=
OCR_V2_DETECTOR_MODE=hybrid
OCR_V2_DETECTOR_MIN_CONF=0.30
OCR_V2_EAST_MIN_CONF=0.55
OCR_V2_MSER_MIN_CONF=0.35
OCR_V2_DETECTOR_MAX_BOXES=6
OCR_V2_DETECTOR_MIN_W=24
OCR_V2_DETECTOR_MIN_H=12
OCR_V2_DETECTOR_MIN_ASPECT=1.2
OCR_V2_DETECTOR_MAX_ASPECT=16.0
OCR_V2_TRACK_IOU_THRESHOLD=0.35
OCR_V2_TRACK_MAX_MISSES=3
OCR_V2_MIN_TRACK_OBSERVATIONS=2
OCR_V2_MIN_TEXT_CONFIDENCE=0.45
OCR_V2_MIN_TEXT_LEN=5
OCR_V2_MIN_TEXT_ALPHA_RATIO=0.55
OCR_V2_MIN_TEXT_ALNUM_RATIO=0.75
OCR_V2_MAX_TEXT_SYMBOL_RATIO=0.20
OCR_V2_FUSE_MIN_SAMPLES=3
OCR_V2_FUSE_SIM_THRESHOLD=0.84
OCR_V2_SEGMENT_MIN_CONFIDENCE=0.45
OCR_V2_SEGMENT_MIN_SAMPLES=3
OCR_V2_SEGMENT_HIGH_CONF_OVERRIDE=0.85
OCR_V2_SMALL_BOX_UPSCALE=2.0
OCR_V2_SMALL_BOX_THRESHOLD_W=120
OCR_V2_SMALL_BOX_THRESHOLD_H=44
# Region text-likelihood pre-gate + persistence
OCR_V2_TARGETED=true
OCR_V2_TARGET_THRESHOLD_LOWER_THIRD=0.22
OCR_V2_TARGET_THRESHOLD_SLIDE=0.26
OCR_V2_TARGET_THRESHOLD_FULL=0.30
OCR_V2_TARGET_PERSIST_RELAX=0.82
OCR_V2_TARGET_FORCE_EVERY_SAMPLES=8
OCR_V2_TARGET_SCENE_CUT_BOOST=0.03
OCR_V2_TARGET_RESIZE_MAX_WIDTH=960
# Optional hard guard for low-resolution OCR inputs
OCR_V2_MIN_VIDEO_WIDTH=1280
OCR_V2_REQUIRE_MIN_VIDEO_WIDTH=false

# OCR v3 (3-lane workflow: slides + lower-third + lyrics)
OCR_V3_SAMPLE_SEC=1.0
# 0 = full duration
OCR_V3_MAX_DURATION_SEC=0
OCR_V3_BACKEND=tesseract
OCR_V3_EAST_ENABLED=true
OCR_V3_EAST_MODEL=
OCR_V3_EAST_MODEL_DIR=
OCR_V3_EAST_AUTO_DOWNLOAD=true
OCR_V3_EAST_URL=
OCR_V3_EAST_SHA256=
OCR_V3_DETECTOR_MODE=hybrid
OCR_V3_DETECTOR_MIN_CONF=0.30
OCR_V3_EAST_MIN_CONF=0.55
OCR_V3_MSER_MIN_CONF=0.35
OCR_V3_DETECTOR_MAX_BOXES=6
OCR_V3_DETECTOR_MIN_W=24
OCR_V3_DETECTOR_MIN_H=12
OCR_V3_DETECTOR_MIN_ASPECT=1.2
OCR_V3_DETECTOR_MAX_ASPECT=16.0
OCR_V3_MIN_TEXT_LEN=5
OCR_V3_MIN_TEXT_CONFIDENCE=0.45
OCR_V3_MIN_TEXT_ALPHA_RATIO=0.55
OCR_V3_MIN_TEXT_ALNUM_RATIO=0.75
OCR_V3_MAX_TEXT_SYMBOL_RATIO=0.20
OCR_V3_SMALL_BOX_UPSCALE=2.0
OCR_V3_SMALL_BOX_THRESHOLD_W=120
OCR_V3_SMALL_BOX_THRESHOLD_H=44
OCR_V3_TARGET_RESIZE_MAX_WIDTH=960

# Lane: Slides
OCR_V3_LANE_SLIDES_ENABLED=true
OCR_V3_SLIDES_Y1=0.06
OCR_V3_SLIDES_Y2=0.62
OCR_V3_SLIDES_X1=0.02
OCR_V3_SLIDES_X2=0.98
OCR_V3_SLIDES_FORCE_EVERY_SAMPLES=10
OCR_V3_SLIDES_PRESENCE_THRESHOLD=0.26
OCR_V3_SLIDES_MERGE_GAP_SEC=2.5
OCR_V3_SLIDES_SIM_THRESHOLD=0.88

# Lane: Lower-third
OCR_V3_LANE_LOWER_THIRD_ENABLED=true
OCR_V3_LOWER_THIRD_DETECT_EVERY_SAMPLES=2
OCR_V3_LOWER_THIRD_PRESENCE_THRESHOLD=0.22
OCR_V3_LOWER_THIRD_TRACK_IOU_THRESHOLD=0.35
OCR_V3_LOWER_THIRD_TRACK_MAX_MISSES=6
OCR_V3_LOWER_THIRD_MIN_TRACK_OBSERVATIONS=2
OCR_V3_LOWER_THIRD_OCR_HASH_DISTANCE=6
OCR_V3_LOWER_THIRD_FUSE_MIN_SAMPLES=3
OCR_V3_LOWER_THIRD_FUSE_SIM_THRESHOLD=0.84
OCR_V3_LOWER_THIRD_SEGMENT_MIN_CONFIDENCE=0.45
OCR_V3_LOWER_THIRD_SEGMENT_MIN_SAMPLES=3
OCR_V3_LOWER_THIRD_SEGMENT_HIGH_CONF_OVERRIDE=0.85

# Lane: Lyrics
OCR_V3_LANE_LYRICS_ENABLED=true
OCR_V3_LYRICS_Y1=0.58
OCR_V3_LYRICS_Y2=0.94
OCR_V3_LYRICS_X1=0.12
OCR_V3_LYRICS_X2=0.88
OCR_V3_LYRICS_PRESENCE_THRESHOLD=0.24
OCR_V3_LYRICS_FORCE_EVERY_SAMPLES=6
OCR_V3_LYRICS_MERGE_GAP_SEC=2.0
OCR_V3_LYRICS_SIM_THRESHOLD=0.88
OCR_V3_LYRICS_MIN_CONFIDENCE=0.50
OCR_V3_LYRICS_MIN_WORDS=4
OCR_V3_LYRICS_STRICT_CLASSIFIER=true
OCR_V3_LYRICS_DROP_NON_LYRIC=true

# Slide OCR v2 (full-screen slides lane, budgeted OCR)
SLIDE_OCR_TWO_PASS_BUDGETED=true
SLIDE_OCR_BUDGET_MAX_CANDIDATES=60
SLIDE_OCR_BUDGET_TRIES_PER_CANDIDATE=2
SLIDE_OCR_BUDGET_DIVERSITY_ENABLED=true
SLIDE_OCR_BUDGET_DIVERSITY_BUCKET_SEC=300
SLIDE_OCR_BUDGET_DIVERSITY_MIN_PER_BUCKET=4

# Boundary scorer OCR integration (direct candidate scoring)
BOUNDARY_ENABLE_OCR_SIGNALS=true
BOUNDARY_OCR_PIPELINE=v1
BOUNDARY_OCR_WINDOW_SEC=18
# Optional boundary-specific OCR pass overrides
BOUNDARY_OCR_SAMPLE_SEC=2.5
BOUNDARY_OCR_MAX_DURATION_SEC=0
BOUNDARY_OCR_V2_SAMPLE_SEC=1.0
BOUNDARY_OCR_V2_MAX_DURATION_SEC=0
BOUNDARY_OCR_V3_SAMPLE_SEC=1.0
BOUNDARY_OCR_V3_MAX_DURATION_SEC=0

# Analysis-doc OCR integration overrides
ANALYSIS_OCR_PIPELINE=v1
ANALYSIS_OCR_SAMPLE_SEC=2.5
ANALYSIS_OCR_MAX_DURATION_SEC=0
ANALYSIS_OCR_V2_SAMPLE_SEC=1.0
ANALYSIS_OCR_V2_MAX_DURATION_SEC=0
ANALYSIS_OCR_V3_SAMPLE_SEC=1.0
ANALYSIS_OCR_V3_MAX_DURATION_SEC=0

# Horizontal sermon clip fades (vertical highlights remain no-fade)
HORIZONTAL_SERMON_FADE_ENABLED=true
HORIZONTAL_SERMON_FADE_IN_SEC=1
HORIZONTAL_SERMON_FADE_OUT_SEC=1

# Vertical dynamic crop (face-tracked, per-window, smoothed)
VERTICAL_DYNAMIC_CROP_ENABLED=true
VERTICAL_DYNAMIC_CROP_WINDOW_SEC=2.8
VERTICAL_DYNAMIC_CROP_SMOOTH_ALPHA=0.18
# Promising vertical clipper profile (v3, 2026-02-25)
VERTICAL_DYNAMIC_CROP_MAX_DELTA_PER_SEC=0.05
VERTICAL_DYNAMIC_CROP_USE_KEYFRAMES=false
VERTICAL_DYNAMIC_CROP_USE_FACEPASS_ID=true
VERTICAL_DYNAMIC_CROP_IDENTITY_MIN_SIM=0.35
VERTICAL_DYNAMIC_CROP_IDENTITY_MARGIN=0.06
VERTICAL_DYNAMIC_CROP_IDENTITY_DET_SIZE=256
VERTICAL_DYNAMIC_CROP_MIN_FACE_H=0.07
VERTICAL_DYNAMIC_CROP_MIN_REL_FACE_H=0.55
VERTICAL_DYNAMIC_CROP_DEADBAND=0.03
VERTICAL_DYNAMIC_CROP_HOLD_WINDOWS=4
VERTICAL_DYNAMIC_CROP_DEADBAND_PX=8
VERTICAL_DYNAMIC_CROP_HYSTERESIS_PX=12
# Optional: set seconds instead of window count for hysteresis confirmation.
VERTICAL_DYNAMIC_CROP_HOLD_SEC=0
VERTICAL_DYNAMIC_CROP_MOTION_DT=0.22
VERTICAL_DYNAMIC_CROP_MAX_ACCEL_PER_SEC2=0.025
VERTICAL_DYNAMIC_CROP_MAX_EXPR_POINTS=180
VERTICAL_DYNAMIC_CROP_FOLLOW_KP=2.5
VERTICAL_DYNAMIC_CROP_FOLLOW_KD=1.6
VERTICAL_DYNAMIC_CROP_ACTIVE_ID_WEIGHT=0.20
VERTICAL_DYNAMIC_CROP_TALK_WEIGHT=0.15
VERTICAL_DYNAMIC_CROP_MOTION_WEIGHT=0.08
VERTICAL_DYNAMIC_CROP_MOTION_FALLBACK_MIN_STRENGTH=0.12
VERTICAL_DYNAMIC_CROP_MOTION_FALLBACK_BLEND=0.35
VERTICAL_DYNAMIC_CROP_COMPOSITION_FACE_WEIGHT=0.95
VERTICAL_DYNAMIC_CROP_LOOKAHEAD_SEC=0.8
VERTICAL_DYNAMIC_CROP_EXPR_SIMPLIFY_EPS=0.006
VERTICAL_DYNAMIC_CROP_KEYFRAME_SEC=3.0
VERTICAL_DYNAMIC_CROP_KEYFRAME_MIN_MOVE=0.03
VERTICAL_DYNAMIC_CROP_KEYFRAME_MAX_HOLD_SEC=8.0
VERTICAL_DYNAMIC_CROP_TRANSITION_SEC=1.8
VERTICAL_DYNAMIC_CROP_GLOBAL_OPTIMIZER=false
VERTICAL_DYNAMIC_CROP_GO_DT=0.08
VERTICAL_DYNAMIC_CROP_GO_LAMBDA_VEL=0.20
VERTICAL_DYNAMIC_CROP_GO_LAMBDA_ACC=1.20
VERTICAL_DYNAMIC_CROP_GO_LAMBDA_JERK=0.60
VERTICAL_DYNAMIC_CROP_GO_ITERS=120
VERTICAL_DYNAMIC_CROP_GO_STEP=0.035
VERTICAL_V3_SMOOTH_DT=0.05
VERTICAL_V3_SMOOTH_ALPHA=0.18
VERTICAL_SHOT_RESETS_ENABLED=true
VERTICAL_SHOT_RESET_MIN_SEG_SEC=0.6
VERTICAL_SCENE_CUT_MIN_GAP_SEC=0.35
VERTICAL_TORSO_X_CENTER_PULL=0.40
VERTICAL_TORSO_BIAS_MULT=1.10
VERTICAL_TORSO_HEADROOM_POS=0.26
VERTICAL_CROP_ZOOM_BASE=1.00
VERTICAL_CROP_ZOOM_MOTION_GAIN=0.08
VERTICAL_CROP_ZOOM_MAX=1.04

# Optional Python override for autocrop/InsightFace calls.
# Example: /Volumes/SSD Daniel/CDV/apps/worker/venv311/bin/python3
WORKER_PYTHON_BIN=
