# Core API keys
OPENAI_API_KEY=
HF_TOKEN=

# Optional model overrides
ANALYZE_OPENAI_MODEL=gpt-5-mini
HIGHLIGHTS_OPENAI_MODEL=gpt-5-mini

# Boundary adjudication / policy
BOUNDARY_ENABLE_SINGLE_LLM_ADJUDICATOR=true
BOUNDARY_POLICY_INCLUDE_PRAYER=true
BOUNDARY_POLICY_INCLUDE_BENEDICTION=true
BOUNDARY_POLICY_INCLUDE_ALTAR_CALL=true
BOUNDARY_POLICY_INCLUDE_RESPONSE_MUSIC=true

# Vertical dynamic crop (face-tracked, per-window, smoothed)
VERTICAL_DYNAMIC_CROP_ENABLED=true
VERTICAL_DYNAMIC_CROP_WINDOW_SEC=1.0
VERTICAL_DYNAMIC_CROP_SMOOTH_ALPHA=0.35
VERTICAL_DYNAMIC_CROP_MAX_DELTA_PER_SEC=0.12
VERTICAL_DYNAMIC_CROP_USE_KEYFRAMES=false
VERTICAL_DYNAMIC_CROP_USE_FACEPASS_ID=true
VERTICAL_DYNAMIC_CROP_IDENTITY_MIN_SIM=0.35
VERTICAL_DYNAMIC_CROP_IDENTITY_DET_SIZE=256
VERTICAL_DYNAMIC_CROP_DEADBAND=0.015
VERTICAL_DYNAMIC_CROP_HOLD_WINDOWS=2
VERTICAL_DYNAMIC_CROP_MOTION_DT=0.10
VERTICAL_DYNAMIC_CROP_MAX_ACCEL_PER_SEC2=0.06
VERTICAL_DYNAMIC_CROP_MAX_EXPR_POINTS=420
VERTICAL_DYNAMIC_CROP_FOLLOW_KP=7.0
VERTICAL_DYNAMIC_CROP_FOLLOW_KD=4.0
VERTICAL_DYNAMIC_CROP_COMPOSITION_FACE_WEIGHT=0.75
VERTICAL_DYNAMIC_CROP_LOOKAHEAD_SEC=1.2
VERTICAL_DYNAMIC_CROP_EXPR_SIMPLIFY_EPS=0.0015
VERTICAL_DYNAMIC_CROP_KEYFRAME_SEC=1.5
VERTICAL_DYNAMIC_CROP_KEYFRAME_MIN_MOVE=0.012
VERTICAL_DYNAMIC_CROP_KEYFRAME_MAX_HOLD_SEC=4.0
VERTICAL_DYNAMIC_CROP_TRANSITION_SEC=1.8
