# Worker-only environment (copy to apps/worker/.env.local)

# Core credentials
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=

# Optional provider keys
HF_TOKEN=
HUGGINGFACE_ACCESS_TOKEN=
ELEVENLABS_API_KEY=

# Worker queue controls
WORKER_RPC_CLAIM_ENABLED=true
WORKER_ID=
WORKER_JOB_LEASE_SECONDS=120
WORKER_POLL_INTERVAL_MS=10000

# Pipeline routing profile
PIPELINE_MODE=local
INGEST_MODE=audio_first
RENDER_SOURCE_POLICY=original_first
ENABLE_RAILWAY_VERTICAL=false
ENABLE_RAILWAY_HORIZONTAL_LOWRES=false
ENABLE_PROXMOX_FULLRES=false
ENABLE_BLOG_ARTIFACT_STAGE=true
DELIVERY_STAGE_ENABLED=true
DELIVERY_ENCODE_HORIZONTAL_LOWRES=false
DELIVERY_ENCODE_HQ_PACKAGE=false

# Full-res storage provider
FULLRES_STORAGE_PROVIDER=none
FULLRES_STORAGE_ENABLED=false
FULLRES_STORAGE_SSH_HOST=
FULLRES_STORAGE_SSH_USER=uploader
FULLRES_STORAGE_SSH_PORT=22
FULLRES_STORAGE_SSH_PATH=/home/uploader/uploads
FULLRES_STORAGE_PUBLIC_BASE_URL=
FULLRES_STORAGE_SSH_IDENTITY_FILE=

# Blog artifact defaults (overridden per client profile when configured)
BLOG_OPENAI_MODEL=gpt-5-mini
BLOG_PROMPT_VERSION=blog-v1
BLOG_DEFAULT_AUTHOR_NAME=Default Author
BLOG_DEFAULT_HERO_IMAGE_URL=
BLOG_SYNC_ENDPOINT=
BLOG_SYNC_BASE_URL=
BLOG_SYNC_TOKEN=

# Ingest quality controls
YTDLP_MIN_PREFERRED_HEIGHT=1080
YTDLP_ALLOW_LOW_QUALITY_FALLBACK=false
YTDLP_REQUIRE_FFPROBE_FOR_QUALITY=true
YTDLP_JS_RUNTIME=auto
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_ENABLE_ANDROID_FALLBACK=true

# Optional Google STT pipeline
GOOGLE_CLOUD_PROJECT=
GOOGLE_STT_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_STT_LOCATION=us
GOOGLE_STT_LANGUAGE=es-US
GOOGLE_STT_MODEL=chirp_3
GOOGLE_STT_MIN_SPEAKERS=2
GOOGLE_STT_MAX_SPEAKERS=8
GOOGLE_STT_SEGMENT_SEC=1140
GOOGLE_STT_MAX_FILES_PER_BATCH=15
GOOGLE_STT_USE_MANAGED_RECOGNIZER=true
GOOGLE_STT_RECOGNIZER_ID=cdv-sermon-diarizer-us

# Optional model overrides
ANALYZE_OPENAI_MODEL=gpt-5-mini
BOUNDARY_LLM_MODEL=gpt-5-mini

# Transcription provider controls
TRANSCRIBE_PROVIDER=local
TRANSCRIBE_STRICT_PROVIDER=false
TRANSCRIBE_ELEVENLABS_MODEL_ID=scribe_v2
TRANSCRIBE_ELEVENLABS_DIARIZE=true
TRANSCRIBE_ELEVENLABS_TAG_AUDIO_EVENTS=true
TRANSCRIBE_ELEVENLABS_TIMESTAMP_GRANULARITY=word
TRANSCRIBE_ELEVENLABS_LANGUAGE_CODE=
TRANSCRIBE_ELEVENLABS_NUM_SPEAKERS=
TRANSCRIBE_ELEVENLABS_TIMEOUT_MS=1800000
TRANSCRIBE_ELEVENLABS_NO_VERBATIM=false
TRANSCRIBE_ELEVENLABS_INCLUDE_AUDIO_EVENTS_IN_TRANSCRIPT=false

# Boundary signal controls
BOUNDARY_ENABLE_AUDIO_SIGNALS=true
AUDIO_EVENT_BACKEND=auto

# Vertical dynamic crop tuning
VERTICAL_DYNAMIC_CROP_WINDOW_SEC=2.8
VERTICAL_DYNAMIC_CROP_SMOOTH_ALPHA=0.18
VERTICAL_DYNAMIC_CROP_MAX_DELTA_PER_SEC=0.05
VERTICAL_DYNAMIC_CROP_DEADBAND=0.03
VERTICAL_DYNAMIC_CROP_HOLD_WINDOWS=4
VERTICAL_DYNAMIC_CROP_MOTION_DT=0.22
VERTICAL_DYNAMIC_CROP_MAX_ACCEL_PER_SEC2=0.025
VERTICAL_DYNAMIC_CROP_FOLLOW_KP=2.5
VERTICAL_DYNAMIC_CROP_FOLLOW_KD=1.6
VERTICAL_DYNAMIC_CROP_LOOKAHEAD_SEC=0.8
VERTICAL_DYNAMIC_CROP_KEYFRAME_SEC=3.0
VERTICAL_DYNAMIC_CROP_KEYFRAME_MIN_MOVE=0.03
VERTICAL_DYNAMIC_CROP_KEYFRAME_MAX_HOLD_SEC=8.0
VERTICAL_DYNAMIC_CROP_EXPR_SIMPLIFY_EPS=0.006
VERTICAL_DYNAMIC_CROP_MAX_EXPR_POINTS=180
VERTICAL_DYNAMIC_CROP_USE_HOLD_RAMP=true
VERTICAL_DYNAMIC_CROP_RAMP_THRESHOLD=0.02
VERTICAL_DYNAMIC_CROP_RAMP_CONFIRM_SEC=0.2
VERTICAL_DYNAMIC_CROP_RAMP_SEC=0.6
VERTICAL_DYNAMIC_CROP_RAMP_DT=0.08
VERTICAL_DYNAMIC_CROP_CUT_MAX_DELTA=0.16
VERTICAL_DYNAMIC_CROP_CUT_MAX_ACCEL=0.12
VERTICAL_DYNAMIC_CROP_IDENTITY_MIN_SIM=0.70
VERTICAL_DYNAMIC_CROP_COMPOSITION_FACE_WEIGHT=0.95
VERTICAL_DYNAMIC_CROP_ALLOW_UNANCHORED=false
VERTICAL_DYNAMIC_CROP_CENTER_GATE=0.18
VERTICAL_SCENE_HOLD_ENABLED=true
VERTICAL_SCENE_HOLD_WINDOW_SEC=2.0
